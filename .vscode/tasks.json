				"--build",
				"--preset",
				"ReleaseSpeed"
			],
			"group": "build",
			"dependsOn": "CMake: Configure ReleaseSpeed",
			"problemMatcher": [
				"$gcc"
			]
		},
		{
			"label": "Compile Debug preset",
			"type": "shell",
			"command": "cmake",
			"args": [
				"--build",
				"--preset",
				"Debug"
			],
			"group": "build"
		},
		{
			"label": "Compile ReleaseSize preset",
			"type": "shell",
			"command": "cmake",
			"args": [
				"--build",
				"--preset",
				"ReleaseSize"
			],
			"group": "build"
		},
